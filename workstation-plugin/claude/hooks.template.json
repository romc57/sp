{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./workstation-plugin/claude/scripts/hook-emit.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./workstation-plugin/claude/scripts/hook-emit.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./workstation-plugin/claude/scripts/hook-emit.mjs"
          }
        ]
      }
    ]
  }
}
