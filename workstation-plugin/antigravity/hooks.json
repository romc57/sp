{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node ./workstation-plugin/antigravity/scripts/session-start.mjs"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node ./workstation-plugin/antigravity/scripts/before-prompt.mjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node ./workstation-plugin/cursor/scripts/pre-tool.mjs"
      }
    ],
    "postToolUse": [
      {
        "command": "node ./workstation-plugin/cursor/scripts/post-tool.mjs"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node ./workstation-plugin/cursor/scripts/before-shell.mjs"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node ./workstation-plugin/cursor/scripts/before-mcp.mjs"
      }
    ],
    "stop": [
      {
        "command": "node ./workstation-plugin/cursor/scripts/stop.mjs"
      }
    ]
  }
}
